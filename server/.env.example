# Copier vers `.env` et renseigner les valeurs réelles.

# MongoDB (local ou Atlas)
DATABASE_URL="mongodb://localhost:27017/school_manager"

# JWT — obligatoire en production (chaîne assez longue, sans guillemets parasites)
JWT_SECRET=changez-moi-par-une-longue-chaine-aleatoire
JWT_EXPIRES_IN=7d

PORT=5000
NODE_ENV=development

# Origines autorisées pour CORS (Next.js)
FRONTEND_URL=http://localhost:3000,http://localhost:3001
