# === server/.env (production VPS) ===
DATABASE_URL="mongodb://127.0.0.1:27017/school_manager"
# Ou MongoDB Atlas :
# DATABASE_URL="mongodb+srv://USER:PASS@cluster.mongodb.net/school_manager?retryWrites=true&w=majority"

JWT_SECRET="remplacer-par-une-longue-chaine-aleatoire-min-32-caracteres"
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=production
TRUST_PROXY=1

# Domaine public HTTPS du front (CORS + liens e-mail)
FRONTEND_URL=https://VOTRE_DOMAINE

# SMTP (optionnel mais recommandé)
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@VOTRE_DOMAINE

# Sécurité production (recommandé)
# SENSITIVE_FIELD_ENCRYPTION_KEY=
# NFC_API_KEY=

# === web/.env.production ===
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_DISABLE_UPLOADS_REWRITE=1
# NEXT_PUBLIC_PRIVACY_EMAIL=privacy@VOTRE_DOMAINE
