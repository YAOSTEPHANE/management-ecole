{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "NEXT_PUBLIC_EXPRESS_UPLOADS_VIA_API_PREFIX": "1"
  },
  "installCommand": "npm install && npm install --prefix web && npm install --prefix server",
  "experimentalServices": {
    "web": {
      "root": "web",
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "nextjs",
      "buildCommand": "npm run build"
    },
    "api": {
      "root": "server",
      "entrypoint": "src/index.ts",
      "routePrefix": "/api",
      "framework": "express",
      "buildCommand": "npm run build"
    }
  }
}
