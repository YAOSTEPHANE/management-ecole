{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "services",
  "experimentalServices": {
    "web": {
      "root": "web",
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "api": {
      "root": "server",
      "entrypoint": "src/index.ts",
      "routePrefix": "/api",
      "framework": "express"
    }
  }
}
