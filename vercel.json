{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "experimentalServices": {
    "web": {
      "root": "web",
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "nextjs",
      "installCommand": "npm install",
      "buildCommand": "npm run build"
    },
    "api": {
      "root": "server",
      "entrypoint": "src/index.ts",
      "routePrefix": "/api",
      "framework": "express",
      "installCommand": "npm install",
      "buildCommand": "npm run build"
    }
  }
}
