# Copier ce fichier vers `.env.local` et adapter si besoin.
# URL de l’API Express (backend `server/`), chemin habituel `/api`.

NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- Même domaine (reverse proxy : Nginx, Caddy, Traefik, etc.) ---
# Le navigateur parle à un seul hôte HTTPS ; /api et /uploads sont routés vers Express, le reste vers Next.
# Utilisez une URL relative pour l’API (recommandé) :
# NEXT_PUBLIC_API_URL=/api
# Ne définissez pas NEXT_PUBLIC_UPLOADS_ORIGIN : les fichiers /uploads utilisent le même hôte que la page.
# Si vous utilisez une URL API absolue sur le MÊME hôte que le front (ex. Vercel + rewrite) et des 404 sur /uploads :
# NEXT_PUBLIC_DISABLE_UPLOADS_REWRITE=1

# Origine dédiée uniquement si l’API et les fichiers statiques sont sur un AUTRE hôte que le front :
# NEXT_PUBLIC_UPLOADS_ORIGIN=https://api.votredomaine.com

# Vercel (experimentalServices : Next + Express sous /api) : les fichiers uploadés sont servis en
# /api/uploads/... . Ce flag réécrit les anciennes URLs BDD `/uploads/...` côté client (voir vercel.json).
# NEXT_PUBLIC_EXPRESS_UPLOADS_VIA_API_PREFIX=1

# Affiché dans la politique de confidentialité (contact RGPD / DPO)
# NEXT_PUBLIC_PRIVACY_EMAIL=privacy@votre-etablissement.fr
